# KINXKit 环境变量配置示例

# ========== API 密钥 ==========

# OpenAI API 密钥
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek API 密钥
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 智谱 AI API 密钥
ZHIPU_AI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========== GitHub 配置 ==========

# GitHub Personal Access Token
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub 用户名
GITHUB_USERNAME=yourusername

# ========== 代理配置 ==========

# HTTP 代理
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890

# 不使用代理的地址
NO_PROXY=localhost,127.0.0.1

# ========== Docker 配置 ==========

# Docker 镜像仓库
DOCKER_REGISTRY=docker.io

# Docker 容器前缀
DOCKER_CONTAINER_PREFIX=kinxkit

# ========== 开发配置 ==========

# 开发模式
NODE_ENV=development

# 调试模式
DEBUG=false

# 测试模式
TEST=false

# 日志级别
LOG_LEVEL=info

# ========== 项目配置 ==========

# 默认项目模板
DEFAULT_TEMPLATE=ai-chatbot

# 默认输出目录
DEFAULT_OUTPUT_DIR=./projects

# 是否自动初始化 Git
AUTO_INIT_GIT=true

# 是否自动创建 GitHub 仓库
AUTO_CREATE_GITHUB=false
